{
  "name": "ForestWatcher",
  "version": "3.3.2",
  "private": true,
  "scripts": {
    "start": "react-native start",
    "start:reset": "yarn start -- --reset-cache",
    "start:clear": "yarn run clear && yarn run start:reset",
    "clear:cache": "rm -rf $TMPDIR/react-native-packager-cache-* && rm -rf $TMPDIR/metro-bundler-cache-* && watchman watch-del-all",
    "clear:modules": "rm -rf node_modules",
    "clear": "yarn run clear:cache && yarn run clear:modules && yarn install",
    "prepare": "patch-package",
    "transifex:extract": "i18next-scanner --config ./app/locales/extract.config.js './app/**/*.{js,jsx}'",
    "transifex:push": "node transifex/transifex-push.js",
    "transifex:pull": "node transifex/transifex-pull.js",
    "transifex:override": "node transifex/transifex-override",
    "android": "react-native run-android",
    "android-clean": "cd android/ && ./gradlew clean && cd ..",
    "ios": "react-native run-ios",
    "release:android": "cd android && ./gradlew assembleRelease",
    "release:ios": "react-native run-ios --configuration Release",
    "release:upstream": "git merge --squash --allow-unrelated-histories --strategy recursive -Xtheirs",
    "lint": "node_modules/.bin/eslint ./app/ --max-warnings=0",
    "lint-fix": "node_modules/.bin/eslint ./app/ --max-warnings=0 --fix",
    "lint:ci": "node_modules/.bin/eslint ./app/ --max-warnings=0 -o reports/lint.html -f html"
  },
  "dependencies": {
    "@invertase/react-native-apple-authentication": "2.4.0",
    "@mapbox/geojson-area": "0.2.2",
    "@mapbox/tilebelt": "1.0.2",
