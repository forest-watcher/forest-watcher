    "@react-native-picker/picker": "^2.9.0",
    "@redux-offline/redux-offline": "2.6.0-native.1",
    "@sentry/react-native": "6.10.0",
    "@sharcoux/slider": "^6.1.1",
    "@tmcw/togeojson": "4.5.0",
    "@transifex/api": "^5.4.0",
    "@turf/bbox": "6.5.0",
